# Trip.com Flights Sales Intelligence Platform — Environment Configuration
# Copy this file to .env and fill in the real values.

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://flights:flights@localhost:5432/flights_sales
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_ECHO=false

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_EXTRACTION_TOPIC=extraction.jobs
KAFKA_CONSUMER_GROUP=extraction-workers

# ── Microsoft Graph / Outlook ──────────────────────────────
# Application permissions (Mail.Read) via client credentials flow
OUTLOOK_TENANT_ID=your-tenant-id
OUTLOOK_CLIENT_ID=your-app-client-id
OUTLOOK_CLIENT_SECRET=your-app-client-secret

# ── Trip Claw LLM API ──────────────────────────────────────
# OpenAI-compatible chat completions endpoint used by Trip.com
TRIP_CLAW_API_URL=http://localhost:8080/v1
TRIP_CLAW_API_KEY=your-api-key
TRIP_CLAW_MODEL=trip-claw-v2
TRIP_CLAW_MAX_RETRIES=3
TRIP_CLAW_MAX_CONTEXT_TOKENS=12000
TRIP_CLAW_RATE_LIMIT_RPM=200

# ── Nudge Engine ───────────────────────────────────────────
NUDGE_COLD_THRESHOLD_DAYS=30
NUDGE_DORMANT_THRESHOLD_DAYS=90
NUDGE_ACTION_ITEM_OVERDUE_THRESHOLD_DAYS=7
NUDGE_OFFER_STALL_THRESHOLD_DAYS=14
NUDGE_ESCALATION_DELAY_DAYS=3
NUDGE_NUDGE_COOLDOWN_HOURS=48
NUDGE_MAX_NUDGES_PER_DAY_PER_EXEC=5
NUDGE_EVALUATION_INTERVAL_MINUTES=15

# ── Ingestion Pipeline ─────────────────────────────────────
INGESTION_POLL_INTERVAL_SECONDS=600
INGESTION_BACKFILL_DAYS=90
INGESTION_MAX_ATTACHMENT_SIZE_MB=25
INGESTION_SUPPORTED_ATTACHMENT_TYPES=pdf,pptx,xlsx,docx,png,jpg
INGESTION_EXCLUDED_SENDERS=noreply@*,calendar@*

# ── Notifications ──────────────────────────────────────────
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
SMTP_RELAY_HOST=smtp.example.com
SMTP_RELAY_PORT=587

# ── App General ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
